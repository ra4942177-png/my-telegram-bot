# --- 3️⃣ معالجة واستخراج النصوص من ملف الـ PDF بدقة ---
@app.on_message(filters.document & filters.private)
async def handle_pdf(client, message):
    if not message.document.file_name.lower().endswith('.pdf'):
        await message.reply_text("❌ عذراً، يرجى إرسال ملف بصيغة PDF فقط!")
        return

    waiting_msg = await message.reply_text("⏳ جاري استخراج النص وتصميم الأسئلة بدقة فائقة... يرجى الانتظار ثوانٍ")

    try:
        pdf_path = await message.download()
        text_content = ""
        doc = fitz.open(pdf_path)
        
        for page in doc[:15]:  
            page_text = page.get_text("text")
            page_text = re.sub(r'\s+', ' ', page_text)
            text_content += page_text + "\n"
        doc.close()

        if os.path.exists(pdf_path):
            os.remove(pdf_path)

        if len(text_content.strip()) < 50:
            await waiting_msg.edit_text("❌ الملف يبدو فارغاً أو يحتوي على صور فقط لا يمكن قراءتها كنص!")
            return

        prompt = (
            "أنت خبير أكاديمي محترف ومصمم اختبارات ذكي. "
            "اقرأ النص المرفق بعناية فائقة، واصنع منه اختباراً شاملاً وعالي الدقة من نوع خيارات متعددة (MCQ) باللغة العربية.\n"
            "شروط إلزامية لتفادي الأخطاء:\n"
            "1. يجب أن تكون جميع الأسئلة دقيقة علمياً ومستوحاة مباشرة من النص.\n"
            "2. يجب صياغة حقل 'explanation' لكل سؤال بشكل وافٍ يشرح بدقة سبب اختيار الإجابة الصحيحة وتوضيحها للمستخدم.\n"
            "3. أخرج النتيجة بصيغة JSON فقط كقائمة من الكائنات (Array of objects)، بدون أي كلام جانبي، مقدمات، أو علامات تنصيص خارج الهيكل المفترض.\n\n"
            "الهيكل المطلوب بدقة:\n"
            '[{"question": "نص السؤال هنا بدقة", "options": ["خيار 1", "خيار 2", "خيار 3", "خيار 4"], "correct_index": 0, "explanation": "توضيح مفصل وعلمي للإجابة الصحيحة هنا"}]\n\n'
            f"النص المراد تحويله لاختبار:\n{text_content}"
        )

        try:
            response = ai_client.models.generate_content(
                model='gemini-2.5-flash',
                contents=prompt,
            )
        except APIError as ae:
            await waiting_msg.edit_text("⚠️ سيرفرات جوجل مضغوطة حالياً، يرجى إعادة إرسال الملف بعد لحظات.")
            return

        clean_text = response.text.strip()
        clean_text = re.sub(r'^```json\s*', '', clean_text)
        clean_text = re.sub(r'\s*```$', '', clean_text)
        
        start_idx = clean_text.find('[')
        end_idx = clean_text.rfind(']')
        if start_idx != -1 and end_idx != -1:
            clean_text = clean_text[start_idx:end_idx+1]

        try:
            quiz_data = json.loads(clean_text)
        except json.JSONDecodeError:
            await waiting_msg.edit_text("❌ حدث تعليق في تنسيق الذكاء الاصطناعي، يرجى المحاولة مرة أخرى.")
            return

        await waiting_msg.delete()

        user_states[message.chat.id] = {
            "questions": quiz_data,
            "current_index": 0,
            "score": 0
        }

        await send_next_question(client, message.chat.id)

    except Exception as e:
        print(f"General Error: {e}")
        await message.reply_text("❌ حدث خطأ أثناء معالجة الملف، يرجى المحاولة مجدداً.")

# --- 4️⃣ دالة إرسال السؤال التالي بتنسيق الأزرار الكيوت الصغيرة ---
async def send_next_question(client, chat_id):
    state = user_states.get(chat_id)
    if not state:
        return

    idx = state["current_index"]
    questions = state["questions"]

    if idx >= len(questions):
        score = state["score"]
        total = len(questions)
        await client.send_message(
            chat_id,
            f"🏁 **خلصت الاختبار يا شطور!** 🎉\n\n"
            f"🎯 درجتك النهائية: **{score} من {total}**\n\n"
            f"**كفوووو ومبدع وربي! 👏🏻👏🏻👏🏻🌟🌟🌟🌼🌼🌼**"
        )
        del user_states[chat_id]
        return

    if idx > 0 and idx % 10 == 0:
        station_num = idx // 10
        msgs = {
            1: "✨ **رهييب وربي! أول 10 أسئلة خلفنا!** استمر بالتألق 👏🌼🌟",
            2: "⭐ **كفو عليك! 20 سؤالاً بإصرار!** احسنتتتء وفخور بك! 🌟🌼👏",
            3: "🔥 **مستوى خارق! 30 سؤالاً!** استمر في اكتساح الاختبار! 👏🌟🌼"
        }
        motivate_text = msgs.get(station_num, "🚀 **تستحق القمة دائماً!** إنجاز مذهل وسريع! 🌼🌟👏")
        continue_btn = InlineKeyboardMarkup([
            [InlineKeyboardButton("إكمال الاختبار الصاروخي 🚀", callback_data="continue_quiz")]
        ])
        await client.send_message(chat_id, motivate_text, reply_markup=continue_btn)
        return

    q = questions[idx]

    # 🌸 تنسيق الأزرار الكيوت: ترتيب الأزرار ليكون كل خيارين بجانب بعض لتقليل الحجم
    buttons = []
    emojis = ["🔵", "🟢", "🔴", "🟡"]
    
    row = []
    for i, option in enumerate(q["options"]):
        button_text = f"{emojis[i % len(emojis)]} {option}"
        row.append(InlineKeyboardButton(button_text, callback_data=f"ans_{i}"))
        
        if len(row) == 2:
            buttons.append(row)
            row = []
            
    if row:
        buttons.append(row)

    text = f"📝 **السؤال رقم {idx + 1}/{len(questions)}**\n\n❓ {q['question']}"

    await client.send_message(
        chat_id,
        text,
        reply_markup=InlineKeyboardMarkup(buttons)
    )

# --- 5️⃣ استقبال ومعالجة ضغطات الأزرار وعرض التوضيح ---
@app.on_callback_query()
async def handle_callback(client, callback_query: CallbackQuery):
    chat_id = callback_query.message.chat.id
    state = user_states.get(chat_id)

    if not state:
        await callback_query.answer("انتهت جلسة هذا الاختبار الحالي.")
        return

    if callback_query.data == "continue_quiz":
        await callback_query.message.delete()
        await send_next_question(client, chat_id)
        return

    idx = state["current_index"]
    questions = state["questions"]
    q = questions[idx]

    chosen_index = int(callback_query.data.split("_")[1])
    correct_index = int(q["correct_index"])

    if chosen_index == correct_index:
        state["score"] += 1
        result_text = "✅ **إجابة صحيحة ومثالية!** 🎉"
        
        try:
            celebrate_msg = await client.send_message(
                chat_id,
                "🌼🌼🌼 **إجابة رائعة ولطيفة! واصل التألق!** 🌼🌼🌼"
            )
            await asyncio.sleep(1)  
            await celebrate_msg.delete()
        except Exception:
            pass
    else:
        correct_option_text = q["options"][correct_index]
        result_text = f"❌ **للأسف إجابة خاطئة!**\n\n💡 الإجابة الصحيحة هي: **{correct_option_text}**"

    if q.get("explanation"):
        result_text += f"\n\nℹ️ **التوضيح العلمي:** {q['explanation']}"

    await callback_query.message.edit_text(
        f"📝 **السؤال رقم {idx + 1}/{len(questions)}**\n\n❓ {q['question']}\n\n{result_text}"
    )

    state["current_index"] += 1
    await send_next_question(client, chat_id)

